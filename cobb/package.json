{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-docker": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --reporters=default --reporters=jest-junit",
    "e2e": "ng e2e",
    "format": "prettier --write \"src/**/*.{ts,html,css,scss,js,jsx,tsx,json}\"",
    "check-format": "prettier --check \"src/**/*.{ts,html,css,scss,js,jsx,tsx,json}\"",
    "lint": "ng lint"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "18.2.2",
    "@angular/cdk": "18.2.2",
    "@angular/common": "18.2.2",
    "@angular/compiler": "18.2.2",
    "@angular/core": "18.2.2",
    "@angular/forms": "18.2.2",
    "@angular/material": "18.2.2",
    "@angular/platform-browser": "18.2.2",
    "@angular/platform-browser-dynamic": "18.2.2",
    "@angular/router": "18.2.2",
    "@types/js-yaml": "^4.0.9",
    "chart.js": "^4.4.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "file-saver": "^2.0.5",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "keycloak-angular": "^16.0.1",
    "keycloak-js": "^25.0.2",
    "rxjs": "^7.8.1",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.2",
    "@angular/cli": "18.2.2",
    "@angular/compiler-cli": "18.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.5.2",
    "@types/uuid": "^11.0.0",
    "angular-eslint": "19.3.0",
    "eslint": "^9.23.0",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-junit": "^16.0.0",
    "jest-preset-angular": "^14.5.5",
    "prettier": "^3.5.0",
    "sass": "^1.83.4",
    "typescript": "~5.4.5",
    "typescript-eslint": "8.27.0"
  }
}
