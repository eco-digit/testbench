<network>
    <name>{name}</name>
    <uuid>{uuid}</uuid>
    <forward mode='nat'>
        <nat>
            <port start='1024' end='65535'/>
        </nat>
        <bandwidth>
            <inbound average='{max_inbound}' peak='{max_inbound}' burst='512000'/>
            <outbound average='{max_outbound}' peak='{max_outbound}' burst='512000'/>
        </bandwidth>
    </forward>
    <bridge name='{bridge}' stp='on' delay='0'/>
    <mac address='{gateway_mac}'/>
    <ip address='{gateway_ip}' netmask='255.255.255.0'>
        <dhcp>
            {dhcp_entries}
        </dhcp>
    </ip>
</network>